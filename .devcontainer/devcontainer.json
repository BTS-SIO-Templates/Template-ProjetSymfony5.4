{
  "name": "Symfony 8.2 Environment (High Productivity)",
  "image": "ghcr.io/bts-sio-templates/symfony5.4-php8.2:8.2",
  
  "customizations": {
    "vscode": {
      "extensions": [
        // --- Cœur PHP & Symfony ---
        "bmewburn.vscode-intelephense-client",
        "symfony.symfony-vscode",             // Support natif des services, routes et autocomplétion YAML
        "xdebug.php-debug",
        "usernamehw.errorlens",
        
        // --- Templating & Frontend (Twig) ---
        "mblode.twig-language-2",             // Coloration et snippets Twig
        "tomsaunders.vscode-twig-lint",       // Vérifie les erreurs de syntaxe Twig en temps réel
        
        // --- POO & Qualité ---
        "satiromarra.vscode-php8-getter-setter", // Remplacement de phproberto (plus moderne)
        "neilbrayfield.php-docblocker",
        "junstyle.php-cs-fixer",
        
        // --- DevOps & Outils Symfony ---
        "sleistner.vscode-fp-ts-snippets",    // Utile si vous faites du JS/TS à côté (Webpack Encore / AssetMapper)
        "mrmlnc.vscode-apache",               // Support de la config Apache
        "tamasfe.even-better-toml",           // Pour les fichiers de config modernes
        "redhat.vscode-yaml",                 // Indispensable pour les services.yaml et routes.yaml
        
        // --- Confort Visuel ---
        "PKief.material-icon-theme",
        "formulahendry.auto-rename-tag"
      ],
      "settings": {
        "php.suggest.basic": false,
        "editor.formatOnSave": true,
        
        // Configuration spécifique Symfony / Twig
        "files.associations": {
          "*.html.twig": "twig"
        },
        "emmet.includeLanguages": {
          "twig": "html"
        },
        
        // On force Intelephense à ignorer les dossiers de cache pour gagner en vitesse
        "intelephense.files.exclude": [
          "**/vendor/**/{Tests,tests}/**",
          "**/var/cache/**",
          "**/public/bundles/**"
        ]
      }
    }
  },
  "forwardPorts": [8000, 8025, 9003], // 9003 est le port par défaut de Xdebug 3
  
  // Commande pour s'assurer que Symfony CLI est à jour ou que les assets sont prêts
  "postCreateCommand": "composer install"
}
