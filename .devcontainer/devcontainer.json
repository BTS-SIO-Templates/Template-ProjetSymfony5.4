{
  "name": "Symfony 8.2 Environment (High Productivity)",
  "image": "ghcr.io/bts-sio-templates/symfony5.4-php8.2:8.2",
  
  "customizations": {
    "vscode": {
      "extensions": [
        // --- Cœur PHP & Symfony ---
        "yzhang.markdown-all-in-one",
        "bmewburn.vscode-intelephense-client",
        "symfony.symfony-vscode",
        "xdebug.php-debug",
        "usernamehw.errorlens",
        "mehedidracula.php-namespace-resolver",
        
        // --- Templating & Frontend (Twig / JS) ---
        "mblode.twig-language-2",
        "tomsaunders.vscode-twig-lint",
        "sleistner.vscode-fp-ts-snippets",    // JS/TS (AssetMapper)
        "formulahendry.auto-rename-tag",
        
        // --- POO & Qualité ---
        "satiromarra.vscode-php8-getter-setter",
        "neilbrayfield.php-docblocker",
        "junstyle.php-cs-fixer",
        
        // --- DevOps & Outils Configuration ---
        "mrmlnc.vscode-apache",               // Config .htaccess / Apache
        "tamasfe.even-better-toml",           // Config TOML
        "redhat.vscode-yaml",                 // Services.yaml, routes.yaml, docker-compose
        
        // --- UI ---
        "PKief.material-icon-theme"
      ],
      "settings": {
        "php.suggest.basic": false,
        "editor.formatOnSave": true,
        
        // Injection de la configuration Xdebug 3
        "php.debug.executablePath": "/usr/local/bin/php",
        "php.ini.values": {
          "xdebug.mode": "debug",
          "xdebug.client_host": "host.docker.internal",
          "xdebug.client_port": "9003",
          "xdebug.start_with_request": "yes"
        },

        // Support spécifique Twig & Emmet
        "files.associations": {
          "*.html.twig": "twig"
        },
        "emmet.includeLanguages": {
          "twig": "html"
        },

        // Optimisation de l'indexation (Intelephense)
        "intelephense.files.exclude": [
          "**/vendor/**/{Tests,tests}/**",
          "**/var/cache/**",
          "**/public/bundles/**"
        ]
      }
    }
  },

  "forwardPorts": [8000, 8025, 9003],
  "remoteUser": "root", 

  "postCreateCommand": "composer install"
}
